#!/bin/bash
# Agent Matrix - 独立启动脚本
# 放置于: ~/Desktop/AgentMatrix/

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
NC='\033[0m' # No Color

# 显示 Banner
show_banner() {
    echo ""
    echo -e "${PURPLE}╔═══════════════════════════════════════════════════╗${NC}"
    echo -e "${PURPLE}║                                                   ║${NC}"
    echo -e "${PURPLE}║      🤖 Agent Matrix - 多 Agent 协作矩阵         ║${NC}"
    echo -e "${PURPLE}║                                                   ║${NC}"
    echo -e "${PURPLE}╚═══════════════════════════════════════════════════╝${NC}"
    echo ""
}

# 显示菜单
show_menu() {
    echo -e "${BLUE}请选择操作:${NC}"
    echo ""
    echo -e "  ${GREEN}1)${NC} 🚀 启动 Dashboard (Web 界面)"
    echo -e "  ${GREEN}2)${NC} 🔍 扫描系统 Agent 工具"
    echo -e "  ${GREEN}3)${NC} 📊 查看 Agent 状态"
    echo -e "  ${GREEN}4)${NC} ⚡ 快速创建任务"
    echo -e "  ${GREEN}5)${NC} 🛠️  配置 Agent 角色"
    echo -e "  ${GREEN}6)${NC} 📖 查看文档"
    echo -e "  ${GREEN}0)${NC} 退出"
    echo ""
}

# 启动 Dashboard
start_dashboard() {
    echo -e "${YELLOW}正在启动 Agent Matrix Dashboard...${NC}"

    # 检查依赖
    if [ ! -d "node_modules" ]; then
        echo -e "${BLUE}安装依赖...${NC}"
        npm install
    fi

    echo -e "${GREEN}启动服务器...${NC}"
    echo -e "${GREEN}🌐 浏览器已自动打开: http://localhost:3000${NC}"
    echo ""

    # 后台启动服务器
    npm start &
    SERVER_PID=$!

    # 等待服务器启动后打开浏览器
    sleep 2
    open http://localhost:3000

    # 等待服务器进程结束
    wait $SERVER_PID
}

# 扫描 Agent
discover_agents() {
    echo -e "${YELLOW}扫描系统中的 Agent 工具...${NC}"
    echo ""
    
    node core/discover.js
}

# 查看状态
show_status() {
    echo -e "${YELLOW}Agent 状态:${NC}"
    echo ""
    
    node core/status.js
}

# 快速创建任务
quick_task() {
    echo -e "${YELLOW}快速创建任务${NC}"
    echo ""
    
    read -p "任务名称: " task_name
    read -p "需求描述: " task_desc
    
    if [ -n "$task_name" ] && [ -n "$task_desc" ]; then
        echo -e "${GREEN}创建任务: $task_name${NC}"
        # 这里可以调用 API 创建任务
        curl -s -X POST http://localhost:3000/api/tasks \
            -H "Content-Type: application/json" \
            -d "{\"name\":\"$task_name\",\"requirement\":\"$task_desc\"}" > /dev/null 2>&1
        
        if [ $? -eq 0 ]; then
            echo -e "${GREEN}任务已创建！请在 Dashboard 中查看。${NC}"
        else
            echo -e "${RED}请先启动 Dashboard (选项 1)${NC}"
        fi
    else
        echo -e "${RED}任务名称和需求描述不能为空${NC}"
    fi
}

# 配置角色
configure_roles() {
    echo -e "${YELLOW}Agent 角色配置${NC}"
    echo ""
    
    echo "可用角色:"
    echo "  1) 🔬 研究员 - 信息收集、文档检索"
    echo "  2) 📐 架构师 - 系统设计、代码审查"
    echo "  3) 💻 开发者 - 核心功能实现"
    echo "  4) ⚡ 快枪手 - 快速原型、批量任务"
    echo "  5) 🧪 测试员 - 测试编写、质量保证"
    echo "  6) 📊 分析师 - 数据分析、报告生成"
    echo "  7) 🔧 运维 - 部署、监控、维护"
    echo "  8) 🤖 助手 - 辅助任务、文档整理"
    echo ""
    
    echo "请在 Dashboard 中进行详细配置。"
}

# 查看文档
show_docs() {
    echo -e "${YELLOW}Agent Matrix 文档${NC}"
    echo ""
    
    if [ -f "README.md" ]; then
        cat README.md
    else
        echo "文档暂未创建，请查看 MATRIX.md"
        if [ -f "MATRIX.md" ]; then
            cat MATRIX.md
        fi
    fi
}

# 主循环
main() {
    show_banner
    
    while true; do
        show_menu
        read -p "请输入选项 [0-6]: " choice
        
        case $choice in
            1)
                start_dashboard
                ;;
            2)
                discover_agents
                ;;
            3)
                show_status
                ;;
            4)
                quick_task
                ;;
            5)
                configure_roles
                ;;
            6)
                show_docs
                ;;
            0)
                echo -e "${GREEN}再见！${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}无效选项，请重新输入${NC}"
                ;;
        esac
        
        echo ""
        read -p "按 Enter 继续..."
        clear
    done
}

# 启动
main
